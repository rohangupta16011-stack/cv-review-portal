ANTHROPIC_API_KEY=your-key-here

# Upstash Redis — create free DB at https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend — for magic-link emails (https://resend.com)
RESEND_API_KEY=
RESEND_FROM="CV Review <noreply@your-domain.com>"

# App URL used in magic-link URLs (don't use BASE_URL — it's a reserved Vite var)
APP_URL=http://localhost:4321

# Google OAuth — create a Web client at https://console.cloud.google.com/apis/credentials
# Authorized JS origins must include this app's URL (http://localhost:4321 in dev, prod URL too).
PUBLIC_GOOGLE_CLIENT_ID=

# Razorpay (phase 2 — payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
PUBLIC_RAZORPAY_KEY_ID=
