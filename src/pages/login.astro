---
import Layout from "../layouts/Layout.astro";
const sent = Astro.url.searchParams.get("sent");
const email = Astro.url.searchParams.get("email") ?? "";
const error = Astro.url.searchParams.get("error");
const claim = Astro.url.searchParams.get("claim") ?? "";

if (Astro.locals.user) {
  return Astro.redirect(claim ? `/r/${claim}` : "/");
}

const claiming = !!claim;
---

<Layout title="Sign in — CV Review">
  <main class="mx-auto max-w-md px-6 py-16">
    <div class="card p-8">
      {sent ? (
        <>
          <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-full bg-teal-50">
            <svg class="h-6 w-6 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
          </div>
          <h1 class="font-display text-2xl font-semibold text-ink mb-2">Check your email</h1>
          <p class="text-ink/70 mb-2">
            We sent a sign-in link to <span class="font-medium text-ink">{email}</span>.
          </p>
          <p class="text-sm text-ink/60">It expires in 15 minutes. You can close this tab.</p>
          <a href={`/login${claim ? `?claim=${claim}` : ""}`} class="block mt-6 text-sm text-teal-600 hover:text-teal-700">Use a different email</a>
        </>
      ) : (
        <>
          {claiming && (
            <div class="mb-5 px-4 py-3 rounded-lg bg-teal-50 border border-teal-600/20 text-sm text-teal-800">
              Sign in to unlock the suggestions on your review.
            </div>
          )}
          <h1 class="font-display text-2xl font-semibold text-ink mb-2">{claiming ? "One more step" : "Sign in"}</h1>
          <p class="text-sm text-ink/60 mb-6">We'll email you a link — no password needed.</p>
          <form method="POST" action="/api/auth/request" class="space-y-4">
            {claim && <input type="hidden" name="claim" value={claim} />}
            <input
              type="email"
              name="email"
              required
              autofocus
              placeholder="you@example.com"
              class="w-full rounded-lg border border-ink/15 bg-white px-4 py-3 text-sm focus:outline-none focus:border-teal-600/60 focus:ring-2 focus:ring-teal-500/20"
            />
            <button type="submit" class="btn-primary w-full">Send sign-in link</button>
          </form>
          {error && (
            <p class="mt-4 text-sm text-coral-500 bg-coral-50 border border-coral-400/20 rounded-lg px-4 py-3">{decodeURIComponent(error)}</p>
          )}
          <p class="mt-6 text-xs text-ink/50">
            We store your CV for 7 days, then auto-delete it.
          </p>
        </>
      )}
    </div>
  </main>
</Layout>
