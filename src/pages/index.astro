---
import Layout from "../layouts/Layout.astro";
import { getRemainingForUser } from "../lib/rate-limit";

const user = Astro.locals.user;
const remaining = user ? await getRemainingForUser(user.id) : null;
---

<Layout title="CV Review Portal — Free AI-powered review in seconds">
  <main class="gradient-hero">
    <div class="mx-auto max-w-4xl px-6 py-12 md:py-20">
      <section class="text-center mb-10 md:mb-14">
        <span class="inline-flex items-center gap-2 rounded-full bg-teal-50 border border-teal-600/20 px-3 py-1 text-xs font-medium text-teal-700 mb-5">
          <span class="h-1.5 w-1.5 rounded-full bg-teal-600"></span>
          Free · No sign-up required for diagnosis
        </span>
        <h1 class="text-4xl md:text-6xl font-display font-semibold text-ink leading-[1.05] mb-5">
          A senior recruiter's read<br/>
          <span class="text-teal-600">on your CV</span> — in 30 seconds.
        </h1>
        <p class="text-lg text-ink/70 max-w-2xl mx-auto">
          Upload your CV and get a scored diagnosis across content, sections,
          and ATS readiness — with the exact bullets, words, and slips holding you back.
        </p>
      </section>

      <section id="uploader" class="card p-8 md:p-12 mb-8">
        <form id="cv-form" class="space-y-6">
          <label
            for="cv-file"
            id="dropzone"
            class="flex flex-col items-center justify-center gap-3 rounded-2xl border-2 border-dashed border-ink/15 bg-cream-50 px-6 py-14 text-center cursor-pointer transition hover:border-teal-600/40 hover:bg-teal-50/30"
          >
            <span class="status-icon status-icon-pass h-14 w-14">
              <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0 3 3m-3-3-3 3M6.75 19.5a4.5 4.5 0 0 1-1.41-8.775 5.25 5.25 0 0 1 10.233-2.33 3 3 0 0 1 3.758 3.848A3.752 3.752 0 0 1 18 19.5H6.75Z" />
              </svg>
            </span>
            <div>
              <span class="font-medium text-ink text-base" id="dropzone-title">Drop your CV here, or click to choose</span>
              <p class="text-sm text-ink/60 mt-1">PDF or DOCX, up to 10MB</p>
            </div>
            <input id="cv-file" name="cv" type="file" accept=".pdf,.docx" class="sr-only" required />
          </label>

          <div class="flex items-center justify-between gap-4">
            <p id="file-name" class="text-sm text-ink/60 truncate"></p>
            <button id="submit-btn" type="submit" class="btn-primary" disabled>
              <span id="btn-label">Run free review</span>
              <svg id="btn-spinner" class="hidden h-4 w-4 animate-spin" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" class="opacity-25"></circle>
                <path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"></path>
              </svg>
            </button>
          </div>

          <p id="error" class="hidden text-sm text-coral-500 bg-coral-50 border border-coral-400/20 rounded-lg px-4 py-3"></p>
          {user && remaining !== null && (
            <p class="text-xs text-ink/50 text-center">{remaining} free review{remaining !== 1 ? "s" : ""} left today</p>
          )}
        </form>

        <div id="loading" class="hidden mt-6 text-center">
          <div class="inline-flex items-center gap-3 text-ink/70">
            <svg class="h-5 w-5 animate-spin text-teal-600" viewBox="0 0 24 24" fill="none">
              <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" class="opacity-25"></circle>
              <path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"></path>
            </svg>
            <span>Reading your CV and generating feedback…</span>
          </div>
          <p class="mt-2 text-xs text-ink/50">This usually takes 10–25 seconds.</p>
        </div>
      </section>

      <!-- Value props -->
      <section class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="card p-5">
          <div class="status-icon status-icon-pass mb-3">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
          </div>
          <h3 class="font-display text-base font-semibold text-ink mb-1">Scored diagnosis</h3>
          <p class="text-sm text-ink/60">Overall score plus three category scores: content, sections, ATS.</p>
        </div>
        <div class="card p-5">
          <div class="status-icon status-icon-warn mb-3">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" /></svg>
          </div>
          <h3 class="font-display text-base font-semibold text-ink mb-1">Specific findings</h3>
          <p class="text-sm text-ink/60">The exact bullets without numbers, repeated verbs, spelling slips, missing sections.</p>
        </div>
        <div class="card p-5">
          <div class="status-icon status-icon-fail mb-3">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 5.25h.008v.008H12v-.008Z" /></svg>
          </div>
          <h3 class="font-display text-base font-semibold text-ink mb-1">Honest, calibrated</h3>
          <p class="text-sm text-ink/60">Calibrated against CVs that get past recruiters at top firms — not a feel-good auto-reply.</p>
        </div>
      </section>
    </div>
  </main>
</Layout>

<script>
  const form = document.getElementById("cv-form") as HTMLFormElement | null;
  if (form) {
    const fileInput = document.getElementById("cv-file") as HTMLInputElement;
    const fileName = document.getElementById("file-name") as HTMLParagraphElement;
    const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
    const btnLabel = document.getElementById("btn-label") as HTMLSpanElement;
    const btnSpinner = document.getElementById("btn-spinner") as unknown as SVGElement;
    const errorEl = document.getElementById("error") as HTMLParagraphElement;
    const loadingEl = document.getElementById("loading") as HTMLElement;
    const dropzone = document.getElementById("dropzone") as HTMLLabelElement;
    const dropzoneTitle = document.getElementById("dropzone-title") as HTMLSpanElement;

    function setError(msg: string) {
      errorEl.textContent = msg;
      errorEl.classList.remove("hidden");
    }
    function clearError() {
      errorEl.classList.add("hidden");
    }

    fileInput.addEventListener("change", () => {
      const f = fileInput.files?.[0];
      if (f) {
        fileName.textContent = f.name;
        submitBtn.disabled = false;
        dropzoneTitle.textContent = f.name;
        clearError();
      }
    });

    dropzone.addEventListener("dragover", (e) => {
      e.preventDefault();
      dropzone.classList.add("border-teal-600/60", "bg-teal-50/50");
    });
    dropzone.addEventListener("dragleave", () => {
      dropzone.classList.remove("border-teal-600/60", "bg-teal-50/50");
    });
    dropzone.addEventListener("drop", (e) => {
      e.preventDefault();
      dropzone.classList.remove("border-teal-600/60", "bg-teal-50/50");
      const f = e.dataTransfer?.files?.[0];
      if (f) {
        const dt = new DataTransfer();
        dt.items.add(f);
        fileInput.files = dt.files;
        fileInput.dispatchEvent(new Event("change"));
      }
    });

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      clearError();
      const file = fileInput.files?.[0];
      if (!file) return;

      submitBtn.disabled = true;
      btnLabel.textContent = "Reviewing…";
      btnSpinner.classList.remove("hidden");
      loadingEl.classList.remove("hidden");

      const fd = new FormData();
      fd.append("cv", file);

      try {
        const res = await fetch("/api/report", { method: "POST", body: fd });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || "Review failed.");
        window.location.href = `/r/${data.id}`;
      } catch (err) {
        setError(err instanceof Error ? err.message : "Something went wrong.");
        submitBtn.disabled = false;
        btnLabel.textContent = "Run free review";
        btnSpinner.classList.add("hidden");
        loadingEl.classList.add("hidden");
      }
    });
  }
</script>
